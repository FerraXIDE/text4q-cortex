# Copy this file to .env and fill in your values
# cp .env.example .env

# IBM Quantum credentials
# Get your token at: https://quantum.ibm.com/
IBM_QUANTUM_TOKEN=your_token_here

# Default backend (e.g. ibm_brisbane, ibm_sherbrooke)
IBM_QUANTUM_BACKEND=ibm_brisbane

# LLM backend for advanced NLP (optional, v0.2+)
# OPENAI_API_KEY=sk-...
